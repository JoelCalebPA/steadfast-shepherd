---
import Layout from "../layouts/Layout.astro";
import Footer from "../components/Footer.astro";
import "../styles/global.css";

const initialLastUpdated = new Date();
---

<Layout>
  <main>
    <div id="progressBar"></div>
    <div id="resultsGrid" class="results-grid">
      <div class="loading-state">
        <div class="spinner"></div>
        <p>Cargando resultados...</p>
      </div>
    </div>
  </main>

  <Footer lastUpdated={initialLastUpdated} />
</Layout>

<script>
  const POLL_INTERVAL = 60 * 1000;
  let isLoading = false;
  let lastResultsHash = "";
  let lastProgressHash = "";

  const candidateColors: Record<string, { color: string; dni: string; partyCode: string }> = {
    "10001088": { color: "#DE722E", dni: "10001088", partyCode: "00000008" },
    "07845838": { color: "#2E699D", dni: "07845838", partyCode: "00000035" },
    "06506278": { color: "#F5D84C", dni: "06506278", partyCode: "00000016" },
    "09177250": { color: "#2A5B1B", dni: "09177250", partyCode: "00000014" },
    "06002034": { color: "#363435", dni: "06002034", partyCode: "00000023" },
    "25331980": { color: "#D62F21", dni: "25331980", partyCode: "00000002" },
    "16002918": { color: "#75BC3B", dni: "16002918", partyCode: "00000010" },
    "07867789": { color: "#1730C3", dni: "07867789", partyCode: "00000033" },
  };

  function getCandidatePhotoUrl(dni: string): string {
    return `https://resultadoelectoral.onpe.gob.pe/assets/img-reales/candidatos/${dni}.jpg`;
  }

  function getPartyLogoUrl(partyCode: string): string {
    return `https://resultadoelectoral.onpe.gob.pe/assets/img-reales/partidos/${partyCode}.jpg`;
  }

  async function fetchAll() {
    if (isLoading) return;
    isLoading = true;

    const grid = document.getElementById("resultsGrid");
    const progressBar = document.getElementById("progressBar");
    const refreshBtns = document.querySelectorAll(".refresh-btn");

    refreshBtns.forEach((btn) => btn.classList.add("loading"));

    try {
      const [resultsResponse, progressResponse] = await Promise.all([
        fetch("/api/results.json"),
        fetch("/api/progress.json"),
      ]);

      const resultsData = await resultsResponse.json();
      const progressData = await progressResponse.json();

      const newResultsHash = JSON.stringify(resultsData.data);
      const newProgressHash = JSON.stringify(progressData.data);

      let dataChanged = false;

      if (newResultsHash !== lastResultsHash) {
        lastResultsHash = newResultsHash;
        if (resultsData.success && resultsData.data) {
          renderResults(resultsData.data, resultsData.fallback);
          dataChanged = true;
        }
      }

      if (newProgressHash !== lastProgressHash) {
        lastProgressHash = newProgressHash;
        if (progressData.success && progressData.data) {
          renderProgress(progressData.data);
          dataChanged = true;
        }
      }

      if (dataChanged) {
        dispatchResultsUpdated();
      }
    } catch (error) {
      console.error("Error fetching data:", error);
    } finally {
      isLoading = false;
      refreshBtns.forEach((btn) => btn.classList.remove("loading"));
    }
  }

  function renderProgress(data: any) {
    const progressBar = document.getElementById("progressBar");
    if (!progressBar) return;

    const formattedCounted = new Intl.NumberFormat("es-PE").format(
      data.contabilizadas || 0
    );
    const formattedTotal = new Intl.NumberFormat("es-PE").format(
      data.totalActas || 1
    );
    const percentage = Number(data.actasContabilizadas || 0).toFixed(2);

    progressBar.innerHTML = `
      <div class="progress-card">
        <div class="progress-header">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M3 3v18h18" />
            <path d="m19 9-5 5-4-4-3 3" />
          </svg>
          <span>Progreso del escrutinio</span>
        </div>
        <div class="progress-bar-container">
          <div class="progress-bar-fill" style="width: ${percentage}%"></div>
        </div>
        <div class="progress-stats">
          <span class="percentage">${percentage}%</span>
          <span class="detail">${formattedCounted} de ${formattedTotal} actas</span>
        </div>
      </div>
    `;
  }

  function renderResults(candidates: any[], fallback: boolean = false) {
    const grid = document.getElementById("resultsGrid");
    if (!grid) return;

    grid.innerHTML = "";

    const container = document.createElement("div");
    container.className = "grid-container";

    const cardsGrid = document.createElement("div");
    cardsGrid.className = "cards-grid";

    candidates.forEach((candidate: any, index: number) => {
      const initials = candidate.nombreCandidato
        .split(" ")
        .filter((word: string) => word.length > 2)
        .slice(0, 2)
        .map((word: string) => word[0])
        .join("")
        .toUpperCase();

      const formattedVotes = new Intl.NumberFormat("es-PE").format(
        candidate.totalVotosValidos
      );
      const percentage = Number(candidate.porcentajeVotosValidos).toFixed(2);

      const candidateInfo = candidateColors[candidate.dniCandidato];
      const barColor = candidateInfo?.color || "#6B7280";
      const photoUrl = candidateInfo ? getCandidatePhotoUrl(candidateInfo.dni) : '';
      const logoUrl = candidateInfo ? getPartyLogoUrl(candidateInfo.partyCode) : '';

      const card = document.createElement("article");
      card.className = "card";
      card.style.setProperty("--bar-color", barColor);
      card.style.animationDelay = `${index * 0.1}s`;

      card.innerHTML = `
        <div class="party-logo-badge">
          <img src="${logoUrl}" alt="${candidate.nombreAgrupacionPolitica}" onerror="this.style.display='none';" />
        </div>
        <div class="candidate-photo">
          <img src="${photoUrl}" alt="${candidate.nombreCandidato}" onerror="this.parentElement.classList.add('photo-error');" />
          <div class="photo-fallback">${initials}</div>
        </div>
        <div class="content">
          <h2 class="candidate-name">${candidate.nombreCandidato}</h2>
          <p class="party-name">${candidate.nombreAgrupacionPolitica}</p>
          <div class="progress-container">
            <div class="progress-bar">
              <div class="progress-fill" style="width: ${percentage}%"></div>
            </div>
            <span class="percentage">${percentage}%</span>
          </div>
          <p class="vote-count">${formattedVotes} votos</p>
        </div>
      `;

      cardsGrid.appendChild(card);
    });

    container.appendChild(cardsGrid);

    if (fallback) {
      const notice = document.createElement("div");
      notice.className = "fallback-notice";
      notice.innerHTML = `
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="10"></circle>
          <path d="M12 16v-4"></path>
          <path d="M12 8h.01"></path>
        </svg>
        <span>Datos de respaldo (API no disponible)</span>
      `;
      container.appendChild(notice);
    }

    grid.appendChild(container);
  }

  function dispatchResultsUpdated() {
    window.dispatchEvent(
      new CustomEvent("resultsUpdated", {
        detail: { timestamp: new Date().toISOString() },
      })
    );
  }

  document.addEventListener("DOMContentLoaded", () => {
    fetchAll();
    setInterval(fetchAll, POLL_INTERVAL);
    window.addEventListener("refreshResults", () => {
      fetchAll();
    });
  });
</script>

<style>
  main {
    flex: 1;
    padding: 1.5rem;
    max-width: 1200px;
    margin: 0 auto;
    width: 100%;
  }

  @media (min-width: 768px) {
    main {
      padding: 2rem;
    }
  }

  :global(.progress-card) {
    background: var(--color-card);
    border-radius: var(--radius-lg);
    padding: 1.25rem;
    margin-bottom: 1.5rem;
    box-shadow: var(--shadow-md);
  }

  :global(.progress-header) {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.75rem;
    font-weight: 600;
    color: var(--color-text);
    font-size: 0.875rem;
  }

  @media (min-width: 640px) {
    :global(.progress-header) {
      font-size: 1rem;
    }
  }

  :global(.progress-header svg) {
    color: var(--color-primary);
    flex-shrink: 0;
  }

  :global(.progress-bar-container) {
    height: 24px;
    background: var(--color-border);
    border-radius: var(--radius-full);
    overflow: hidden;
    margin-bottom: 0.5rem;
  }

  :global(.progress-bar-fill) {
    height: 100%;
    background: linear-gradient(
      90deg,
      var(--color-primary) 0%,
      var(--color-primary-light) 100%
    );
    border-radius: var(--radius-full);
    transition: width 0.5s ease-out;
    animation: growProgress 0.8s ease-out;
  }

  @keyframes growProgress {
    from {
      width: 0%;
    }
  }

  :global(.progress-stats) {
    display: flex;
    justify-content: space-between;
    font-size: 0.875rem;
  }

  :global(.progress-stats .percentage) {
    font-weight: 700;
    color: var(--color-primary);
  }

  :global(.progress-stats .detail) {
    color: var(--color-text-muted);
  }

  :global(.grid-container) {
    width: 100%;
  }

  :global(.cards-grid) {
    display: grid;
    gap: 1rem;
    grid-template-columns: 1fr;
  }

  @media (min-width: 640px) {
    :global(.cards-grid) {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  :global(.card) {
    background: var(--color-card);
    border-radius: var(--radius-lg);
    padding: 1rem;
    padding-top: 1.5rem;
    box-shadow: var(--shadow-md);
    display: flex;
    flex-direction: row;
    align-items: flex-start;
    gap: 1rem;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
    animation: slideIn 0.4s ease-out backwards;
    position: relative;
    overflow: hidden;
  }

  :global(.card::before) {
    content: "";
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 4px;
    background: var(--bar-color);
  }

  :global(.card:hover) {
    transform: translateY(-2px);
    box-shadow: var(--shadow-lg);
  }

  :global(.party-logo-badge) {
    position: absolute;
    top: 0.75rem;
    right: 0.75rem;
    width: 32px;
    height: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: white;
    border-radius: var(--radius-sm);
    padding: 2px;
    box-shadow: var(--shadow-sm);
    z-index: 10;
  }

  :global(.party-logo-badge img) {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  :global(.candidate-photo) {
    width: 80px;
    height: 80px;
    min-width: 80px;
    border-radius: 50%;
    overflow: hidden;
    border: 3px solid var(--bar-color);
    position: relative;
    background: var(--bar-color);
  }

  @media (min-width: 640px) {
    :global(.candidate-photo) {
      width: 100px;
      height: 100px;
      min-width: 100px;
    }
  }

  :global(.candidate-photo img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  :global(.candidate-photo.photo-error img) {
    display: none;
  }

  :global(.photo-fallback) {
    position: absolute;
    inset: 0;
    background: var(--bar-color);
    color: white;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.5rem;
    font-weight: 700;
  }

  :global(.candidate-photo.photo-error .photo-fallback) {
    display: flex;
  }

  :global(.candidate-photo:not(.photo-error) .photo-fallback) {
    display: none;
  }

  :global(.content) {
    flex: 1;
    min-width: 0;
  }

  :global(.candidate-name) {
    font-size: 1rem;
    font-weight: 600;
    margin: 0 0 0.25rem 0;
    color: var(--color-text);
    line-height: 1.3;
    padding-right: 2.5rem;
  }

  @media (min-width: 640px) {
    :global(.candidate-name) {
      font-size: 1.125rem;
    }
  }

  :global(.party-name) {
    font-size: 0.75rem;
    color: var(--color-text-muted);
    margin: 0 0 0.75rem 0;
    line-height: 1.4;
  }

  @media (min-width: 640px) {
    :global(.party-name) {
      font-size: 0.875rem;
    }
  }

  :global(.progress-container) {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.5rem;
  }

  :global(.progress-bar) {
    flex: 1;
    height: 12px;
    background: var(--color-border);
    border-radius: var(--radius-full);
    overflow: hidden;
  }

  :global(.progress-fill) {
    height: 100%;
    background: var(--bar-color);
    border-radius: var(--radius-full);
    transition: width 0.8s ease-out;
    animation: growBar 1s ease-out;
  }

  :global(.percentage) {
    font-size: 0.875rem;
    font-weight: 700;
    color: var(--bar-color);
    min-width: 3.5rem;
    text-align: right;
  }

  :global(.vote-count) {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    margin: 0;
    font-weight: 500;
  }

  :global(.fallback-notice) {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 0.75rem;
    background: rgba(245, 158, 11, 0.1);
    border: 1px solid rgba(245, 158, 11, 0.3);
    border-radius: var(--radius-md);
    margin-top: 1rem;
    color: #b45309;
    font-size: 0.875rem;
  }

  :global(.fallback-notice svg) {
    flex-shrink: 0;
  }

  :global(.refresh-btn.loading svg) {
    animation: spin 1s linear infinite;
  }

  @keyframes spin {
    from {
      transform: rotate(0deg);
    }
    to {
      transform: rotate(360deg);
    }
  }

  .results-grid {
    width: 100%;
  }

  .loading-state {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 4rem 2rem;
    color: var(--color-text-muted);
  }

  .spinner {
    width: 40px;
    height: 40px;
    border: 3px solid var(--color-border);
    border-top-color: var(--color-primary);
    border-radius: 50%;
    animation: spin 1s linear infinite;
    margin-bottom: 1rem;
  }
</style>
