---
interface Props {
  actasContabilizadas?: number;
  contabilizadas?: number;
  totalActas?: number;
  loading?: boolean;
}

const {
  actasContabilizadas = 0,
  contabilizadas = 0,
  totalActas = 1,
  loading = false,
} = Astro.props;

const formattedCounted = new Intl.NumberFormat("es-PE").format(contabilizadas);
const formattedTotal = new Intl.NumberFormat("es-PE").format(totalActas);
const percentage = Number(actasContabilizadas).toFixed(2);
---

<div class="progress-card">
  <div class="progress-header">
    <svg
      xmlns="http://www.w3.org/2000/svg"
      width="20"
      height="20"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
    >
      <path d="M3 3v18h18" />
      <path d="m19 9-5 5-4-4-3 3" />
    </svg>
    <span>Progreso del escrutinio</span>
  </div>

  <div class="progress-bar-container">
    <div class="progress-bar-fill" style={`width: ${percentage}%`}></div>
  </div>

  <div class="progress-stats">
    <span class="percentage">{percentage}%</span>
    <span class="detail">{formattedCounted} de {formattedTotal} actas</span>
  </div>
</div>

<style>
  .progress-card {
    background: var(--color-card);
    border-radius: var(--radius-lg);
    padding: 1.25rem;
    margin-bottom: 1.5rem;
    box-shadow: var(--shadow-md);
  }

  .progress-header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.75rem;
    font-weight: 600;
    color: var(--color-text);
    font-size: 0.875rem;
  }

  @media (min-width: 640px) {
    .progress-header {
      font-size: 1rem;
    }
  }

  .progress-header svg {
    color: var(--color-primary);
    flex-shrink: 0;
  }

  .progress-bar-container {
    height: 24px;
    background: var(--color-border);
    border-radius: var(--radius-full);
    overflow: hidden;
    margin-bottom: 0.5rem;
  }

  .progress-bar-fill {
    height: 100%;
    background: linear-gradient(
      90deg,
      var(--color-primary) 0%,
      var(--color-primary-light) 100%
    );
    border-radius: var(--radius-full);
    transition: width 0.5s ease-out;
    animation: growBar 0.8s ease-out;
  }

  @keyframes growBar {
    from {
      width: 0%;
    }
  }

  .progress-stats {
    display: flex;
    justify-content: space-between;
    font-size: 0.875rem;
  }

  .progress-stats .percentage {
    font-weight: 700;
    color: var(--color-primary);
  }

  .progress-stats .detail {
    color: var(--color-text-muted);
  }
</style>
