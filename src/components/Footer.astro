---
interface Props {
  lastUpdated?: Date | null;
}

const { lastUpdated } = Astro.props;

function formatTimeAgo(date: Date | null): string {
  if (!date) return "Nunca";

  const now = new Date();
  const diffMs = now.getTime() - date.getTime();
  const diffMins = Math.floor(diffMs / 60000);

  if (diffMins < 1) return "Hace menos de un minuto";
  if (diffMins === 1) return "Hace 1 minuto";
  if (diffMins < 60) return `Hace ${diffMins} minutos`;

  const diffHours = Math.floor(diffMins / 60);
  if (diffHours === 1) return "Hace 1 hora";
  return `Hace ${diffHours} horas`;
}
---

<footer class="footer">
  <div class="footer-content">
    <div class="source">
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="16"
        height="16"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <circle cx="12" cy="12" r="10" />
        <path d="M12 16v-4" />
        <path d="M12 8h.01" />
      </svg>
      <span>Fuente: ONPE - Oficina Nacional de Procesos Electorales</span>
    </div>

    <div class="last-updated" id="lastUpdated">
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="16"
        height="16"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <circle cx="12" cy="12" r="10" />
        <polyline points="12 6 12 12 16 14" />
      </svg>
      <span id="lastUpdatedText">{formatTimeAgo(lastUpdated)}</span>
    </div>

    <button class="refresh-btn" id="footerRefreshBtn">
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="16"
        height="16"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <path d="M21 12a9 9 0 0 0-9-9 9.75 9.75 0 0 0-6.74 2.74L3 8" />
        <path d="M3 3v5h5" />
        <path d="M3 12a9 9 0 0 0 9 9 9.75 9.75 0 0 0 6.74-2.74L21 16" />
        <path d="M16 16h5v5" />
      </svg>
      <span>Actualizar</span>
    </button>
  </div>
</footer>

<style>
  .footer {
    background: var(--color-card);
    border-top: 1px solid var(--color-border);
    padding: 1rem 1.5rem;
    margin-top: auto;
  }

  .footer-content {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    align-items: center;
    text-align: center;
  }

  @media (min-width: 640px) {
    .footer-content {
      flex-direction: row;
      justify-content: space-between;
      text-align: left;
    }
  }

  .source,
  .last-updated {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.75rem;
    color: var(--color-text-muted);
  }

  .source svg,
  .last-updated svg {
    flex-shrink: 0;
  }

  .refresh-btn {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 1rem;
    background: transparent;
    color: var(--color-primary);
    border: 1px solid var(--color-primary);
    border-radius: var(--radius-md);
    font-size: 0.75rem;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .refresh-btn:hover {
    background: var(--color-primary);
    color: white;
  }

  .refresh-btn:active {
    transform: scale(0.98);
  }
</style>

<script define:vars={{ initialTime: lastUpdated?.toISOString() || null }}>
  let lastUpdateTime = initialTime ? new Date(initialTime) : null;

  function updateLastUpdatedText() {
    const textEl = document.getElementById("lastUpdatedText");
    if (!textEl || !lastUpdateTime) return;

    const now = new Date();
    const diffMs = now.getTime() - lastUpdateTime.getTime();
    const diffMins = Math.floor(diffMs / 60000);

    let text = "Hace menos de un minuto";
    if (diffMins >= 1) {
      text = diffMins === 1 ? "Hace 1 minuto" : `Hace ${diffMins} minutos`;
    }

    textEl.textContent = text;
  }

  setInterval(updateLastUpdatedText, 30000);

  window.addEventListener("resultsUpdated", (e) => {
    if (e.detail?.timestamp) {
      lastUpdateTime = new Date(e.detail.timestamp);
      updateLastUpdatedText();
    }
  });

  const footerRefreshBtn = document.getElementById("footerRefreshBtn");
  if (footerRefreshBtn) {
    footerRefreshBtn.addEventListener("click", () => {
      window.dispatchEvent(new CustomEvent("refreshResults"));
    });
  }
</script>
